    "# Step 1: Map the problem\n",
    "# requires the oracle to be a balanced or constant function\n",
    "# ensures that if the function is constant -> all qubits will end with state zero\n",
    "# ensures that if the function is balances -> at least one of the qubits will have a state of 1\n",
    "qc_dj.h(range(n + 1))\n",
    "qc_dj.barrier()\n",
    "qc_dj.compose(oracle, inplace=True)\n",
    "qc_dj.barrier()\n",
    "qc_dj.h(range(n))\n",
    "# assert either all entangled so all 0 or all 1 or entangled so half 0 half 1\n",
    "qc_dj.measure(range(n), range(n))\n",
    "# if measures all 0s then constant, if any 1s then balanced\n",
    "qc_dj.decompose().decompose()\n",
    "\n",
    "\n",
    "qc_dj.draw(\"mpl\")"
   ]
